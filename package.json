{
  "name": "toss-invest-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the official Toss Securities Open API",
  "type": "module",
  "bin": {
    "toss-invest-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "spec",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "check": "tsc -p tsconfig.json --noEmit",
    "verify": "node scripts/verify.mjs"
  },
  "keywords": [
    "mcp",
    "toss",
    "tossinvest",
    "openapi"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
