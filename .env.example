# Required. Issued from Toss Securities WTS > Settings > Open API.
# Copy this file to .env.local and put real values there. .env.local is gitignored.
TOSSINVEST_CLIENT_ID=
TOSSINVEST_CLIENT_SECRET=

# Optional. Used by account, asset, order, and order-info API tools when
# accountSeq is not passed as a tool argument.
TOSSINVEST_ACCOUNT=

# Optional. Defaults to the official production server in spec/openapi.json.
TOSSINVEST_BASE_URL=https://openapi.tossinvest.com

# Optional. READ_ONLY is the default. DRY_RUN enables order-preparation workflows
# only. LIVE_TRADING is required before create/modify/cancel tools can call Toss.
TOSSINVEST_TRADING_MODE=READ_ONLY

# Backward-compatible legacy switch. Prefer TOSSINVEST_TRADING_MODE.
TOSSINVEST_ENABLE_TRADING=false

# Optional retry settings for 429 and 5xx responses.
TOSSINVEST_MAX_RETRIES=2
TOSSINVEST_RETRY_BASE_DELAY_MS=500
TOSSINVEST_RETRY_MAX_DELAY_MS=5000

# Optional live-trading policy controls.
TOSSINVEST_ALLOWED_SYMBOLS=
TOSSINVEST_BLOCKED_SYMBOLS=
TOSSINVEST_MAX_ORDER_AMOUNT_KRW=
TOSSINVEST_MAX_ORDER_AMOUNT_USD=
TOSSINVEST_REQUIRE_CLIENT_ORDER_ID=true
TOSSINVEST_ALLOW_MARKET_ORDER_WITHOUT_PRICE=false

# Optional local JSONL audit log. Does not log ClientId, Secret, or tokens.
TOSSINVEST_AUDIT_LOG=true
TOSSINVEST_AUDIT_LOG_PATH=audit/toss-invest-mcp-audit.jsonl

# Optional for --http mode.
PORT=3000
MCP_HTTP_PATH=/mcp
MCP_HTTP_BEARER_TOKEN=
MCP_ALLOWED_ORIGIN=*
